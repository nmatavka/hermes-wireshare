<?xml version="1.0" encoding="UTF-8"?>

<!-- top level ant file -->
<project name="limewire" default="build.jar" basedir="." xmlns:ivy="antlib:org.apache.ivy.ant">
    <echo>Java Version via Ant: ${ant.java.version}</echo>
	
	<property name="limewire.home" location="${basedir}"/>
    <property name="includes" value="*/*/build.xml"/>
    
    <property name="aggregate.jar-jarname" value="build/osx/WireShare.jar"/>
    <property name="aggregate.jar-includes" value="*/*/dist/main/*.jar"/>
	
    <import file="components/common/generic-multi-build.xml"/>
	
	<target name="build.jar" description="build OSX WireShare.jar" depends="aggregate.jar">
		<jar destfile="build/osx/WireShare.jar"  update="true" filesetmanifest="skip" compress="true" duplicate="preserve">
       		<fileset dir="lib/resources/osx">
       			<include name="xulrunner-macosx-i386.zip"/>
       		</fileset>
			<archives>
				<zips>
					<fileset dir="lib/jars" includes="*.jar"/>
		       		<fileset dir="lib/jars/osx" includes="*.jar"/>
				</zips>
			</archives>
			<manifest>
		    	<attribute name="Main-Class" value="org.limewire.ui.swing.Main"/>
				<attribute name="SplashScreen-Image" value="org/limewire/ui/swing/mainframe/resources/splash.png"/>
		    </manifest>
		</jar>
	</target>

	<target name="Apple Java6" description="Create an .app package for MacOSX">
	
	    <!-- Set this property value to the directory where you 
	         would like to create the application package -->
	    <property name="macosx.app" value="build/osx/dist"/>
	
	    <!-- Create the release directory -->
	    <mkdir dir="${macosx.app}"/>
	
	    <!-- Set this property value to your application name.
	         Do not include the .app extension -->
	    <property name="app.name" value="WireShare"/>
	
	    <!-- Set this property value to your MacOSX resource 
	         directory (where are stored your JavaApplicationStub 
	         and icon files) -->
	    <property name="macosx.resrc" value="build/osx/MacOSX"/>
	
	    <!-- Set this property value to your application 
	         resource directory (where are stored your 
	         libraries, jar, etc.) -->
	    <property name="app.resrc" value="build/osx"/>
	
	    <property name="macosx.stubfile" value="${macosx.resrc}/JavaApplicationStub"/>
	
	    <taskdef name="jarbundler"
				classname="net.sourceforge.jarbundler.JarBundler"
				classpath="lib/jars/ant/jarbundler-2.3.1.jar"/>
	
	    <!-- Delete the old .app if it exists -->
	    <delete dir="${macosx.app}/${app.name}.app" quiet="yes" failonerror="false"/>
	
	    <!-- This creates the .app for MacOSX.
	         The mainclass property must be set to the name of 
	         the main class to run. -->
	    <jarbundler dir="${macosx.app}"
			verbose="true"
	    	name="${app.name}"
			version="5.6.3.1"
			shortname="${app.name}"
			jar="${app.resrc}/WireShare.jar"
			mainclass="org.limewire.ui.swing.Main"
			icon="${macosx.resrc}/${app.name}.icns"
			infostring="${app.name}"
			stubfile="${macosx.stubfile}"
			workingdirectory="$APP_PACKAGE/Contents/Resources/Java"
	    	extraclasspath="/System/Library/Java"
	    	signature="WSHR"
	    	bundleid="com.limegroup.gnutella"
	    	jvmversion="1.6+"
	    	LSArchitecturePriority="i386 x86_64"
	    	vmoptions="-ea:com.limegroup... -ea:org.limewire... -Xms128m -Xmx512m -XX:MaxPermSize=256m -XX:PermSize=256m">

	    	<!-- The below Java properties can be set to get a better MacOSX look-and-feel -->
	    	<javaproperty name="apple.laf.useScreenMenuBar" value="true"/>
	        <javaproperty name="apple.awt.brushMetalRounded" value="true"/>
	        <javaproperty name="apple.awt.showGrowBox" value="true"/>
	    	
	        <!-- You may need to set here other java properties according to your application needs -->
	    	<javaproperty name="java.net.preferIPV6Addresses" value="false"/>
	    	<javaproperty name="java.net.preferIPv4stack" value="true"/>
	    	<javaproperty name="org.apache.commons.logging.Log" value="org.apache.commons.logging.impl.NoOpLog"/>
	    	<javaproperty name="java.library.path" value="$APP_PACKAGE/Contents/Resources/Java"/>
	    	<javaproperty name="jna.library.path" value="$APP_PACKAGE/Contents/Resources/Java"/>
	    	
	    	<!-- You may need to set here other properties according to your application needs. -->
	    	<LSMinimumSystemVersionByArchitecture arch="x86_64" version="10.5.0"/>
	    	<LSMinimumSystemVersionByArchitecture arch="i386" version="10.6.0"/>
	    	
	    	<!-- Include all the needed files to your application package. -->
	    	<javafileset dir="lib/native/osx"/>
	    	<javafileset dir=".">
	    		<include name="lib/WSHome.xhtml"/>
	    		<include name="lib/bootstrap"/>
	    		<include name="lib/img/TPB.jpg"/>
	    		<include name="lib/img/WireShare-Logo.png"/>
	    	</javafileset>
	    	<resourcefileset dir="lib/resources/osx">
	    		<include name="*.lproj/*"/>
	    		<include name="*.icns"/>
	    	</resourcefileset>

	    	<urltype name="Magnet"
		    	iconFile="LimeWire.icns" 
	        	role="None" 
	        	schemes="magnet"/>
	    	
	        <documenttype name="Packaged Media File"
	        	extensions="pmf"
	        	iconFile="pmf.icns"
	        	role="Viewer"/>
	    	
	        <documenttype name="BitTorrent Metainfo"
	        	extensions="torrent"
	        	iconFile="torrent.icns" 
	        	role="Editor"
	        	mimetypes="application/x-bittorrent"/>
	    </jarbundler>
	</target>
	
	<target name="Oracle Java7" description="Create an .app package for MacOSX">
	    <taskdef name="bundleapp"
             classname="com.oracle.appbundler.AppBundlerTask"   
             classpath="lib/jars/ant/appbundler-1.0ea.jar" />

        <bundleapp outputdirectory="build/osx"
            name="WireShare"
            displayname="WireShare"
            identifier="com.limegroup.gnutella"
        	icon="lib/resources/osx/WireShare.icns"
        	signature="WSHR"
            WorkingDirectory="$APP_ROOT/Contents/Java"
		mainclassname="org.limewire.ui.swing.Main">
            <classpath file="build/osx/WireShare.jar" />
	    	<classpath dir="lib/native/osx"/>
	    	<classpath dir=".">
	    		<include name="lib/WSHome.xhtml"/>
	    		<include name="lib/bootstrap"/>
	    		<include name="lib/img/TPB.jpg"/>
	    		<include name="lib/img/WireShare-Logo.png"/>
	    	</classpath>
        	<option value="-Xdock:icon=Contents/Resources/WireShare.icns}"/>

	        <!-- OSX specific options, optional -->
	        <option value="-Dapple.laf.useScreenMenuBar=true"/>
        	<option value="-Dapple.awt.brushMetalRounded=true"/>
        	<option value="-Dapple.awt.showGrowBox=true"/>
        	        	        	
        	<!-- You may need to set here other java properties according to your application needs -->
        	<option value="-Djava.net.preferIPV6Addresses=false"/>
	    	<option value="-Djava.net.preferIPv4stack=true"/>
	    	<option value="-Dorg.apache.commons.logging.Log=org.apache.commons.logging.impl.NoOpLog"/>
	    	<option value="-Djava.library.path=$APP_ROOT/Contents/Java"/>
	    	<option value="-Djna.library.path=$APP_ROOT/Contents/Java"/>
        	        	
	        <option value="-ea:com.limegroup..."/>
        	<option value="-ea:org.limewire..."/>
        	<option value="-Xms128m"/>
        	<option value="-Xmx512m"/>
        	<option value="-XX:MaxPermSize=256m"/>
        	<option value="-XX:PermSize=256m"/>

        </bundleapp>
	</target>
</project>
	